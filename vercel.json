{
  "buildCommand": "npx prisma generate --schema=backend/prisma/schema.prisma && npm run build:api && npm run build:frontend",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "framework": null,
  "crons": [
    {
      "path": "/api/cron/update-quotes",
      "schedule": "0 12 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ]
}
