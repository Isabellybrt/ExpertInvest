{
  "name": "expert-invest",
  "version": "1.0.0",
  "private": true,
  "description": "Investment Portfolio Manager - Monorepo",
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "build:api": "esbuild src-api/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=api/index.js --external:@prisma/client --external:prisma",
    "test": "npm run test --workspaces",
    "test:frontend": "npm run test --workspace=frontend",
    "test:backend": "npm run test --workspace=backend"
  },
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "devDependencies": {
    "@vercel/node": "^5.8.17",
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "prisma": "^6.19.3"
  }
}
