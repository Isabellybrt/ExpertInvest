# =====================
# Database Connection
# =====================

# DATABASE_URL: Used by Prisma Client for runtime queries.
# Uses the Neon connection pooler endpoint (host contains `-pooler` suffix), port 5432.
#
# Examples:
#   Local PostgreSQL: postgresql://USER:PASSWORD@localhost:5432/DATABASE
#   Neon dev branch:  postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech:5432/DATABASE?sslmode=require
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-cool-band-aiqkplbp-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# DIRECT_URL: Used by Prisma Migrate for schema migrations via direct connection.
# Uses the Neon direct endpoint (host without `-pooler` suffix).
# Optional: only required when using Neon pooled connections. Not needed for local PostgreSQL.
DIRECT_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-cool-band-aiqkplbp.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT secrets for authentication
JWT_SECRET="your-jwt-secret-key-here"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-key-here"

# Google OAuth 2.0 configuration
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
